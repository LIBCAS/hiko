APP_NAME="Památky a společnost v soukromé korespondenci"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost    # The URL will be tenantX.localhost
APP_VERSION=

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Default tenant connection
DB_CONNECTION=tenant
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

PROD_DB_HOST=
PROD_DB_PORT=
PROD_DB_DATABASE=
PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_TIMEOUT=5

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
SESSION_DRIVER=database
SESSION_CONNECTION=tenant
SESSION_LIFETIME=120
# SESSION_DOMAIN=.localhost   # Set a non-null value if you do not want to share cookies across subdomains (tenants) of the same domain
SESSION_SECURE_COOKIE=false

REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=
REDIS_CLIENT=predis

MAIL_MAILER=sendmail
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

GEONAMES_USERNAME=
SHOW_WATERMARK=false
MAIN_CHARACTER_ID=2960
METADATA_DEFAULT_LOCALE=cs

SCOUT_DRIVER=tntsearch

GOOGLE_CLOUD_KEY_FILE=/storage/app/google-cloud/....json
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PROCESSOR_LOCATION=
GOOGLE_CLOUD_PROCESSOR_ID=

GEMINI_API_KEY=
OPENAI_API_KEY=

QUEUE_CONNECTION=database
SCOUT_DRIVER=database

PAGE_LOCK_TTL_SECONDS=60
PAGE_LOCK_HEARTBEAT_SECONDS=15
PAGE_LOCK_GRACE_SECONDS=5

# API V2 configuration for testing
API_V2_BASE_URL=# https://tenantX.localhost
API_V2_BEARER_TOKEN=# 9|FNOq...
API_V2_RUN_LIVE=1
API_V2_CURL_INSECURE=1
API_V2_PRINT_CURL_COMMANDS=1
